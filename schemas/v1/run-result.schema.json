{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/giantsoup/architect-engineer-agentic-harness/schemas/v1/run-result.schema.json",
  "title": "RunResult",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "summary"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["success", "failed", "stopped"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "convergence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "duplicateExplorationSuppressions",
        "explorationBudget",
        "explorationBudgetExhaustedAtStep",
        "repeatedListingCount",
        "repeatedReadCount",
        "repoMemoryHits",
        "stepsToFirstCheck",
        "stepsToFirstEdit"
      ],
      "properties": {
        "duplicateExplorationSuppressions": {
          "type": "integer"
        },
        "explorationBudget": {
          "type": "integer"
        },
        "explorationBudgetExhaustedAtStep": {
          "type": ["integer", "null"]
        },
        "repeatedListingCount": {
          "type": "integer"
        },
        "repeatedReadCount": {
          "type": "integer"
        },
        "repoMemoryHits": {
          "type": "integer"
        },
        "stepsToFirstCheck": {
          "type": ["integer", "null"]
        },
        "stepsToFirstEdit": {
          "type": ["integer", "null"]
        }
      }
    },
    "git": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "createdCommits",
        "dirtyWorkingTreePolicy",
        "errors",
        "warnings"
      ],
      "properties": {
        "dirtyWorkingTreePolicy": {
          "type": "string",
          "enum": ["stop"]
        },
        "dirtyWorkingTreeOutcome": {
          "type": "string",
          "enum": ["clean", "stopped"]
        },
        "startingBranch": {
          "type": "string",
          "minLength": 1
        },
        "startingCommit": {
          "type": "string",
          "minLength": 1
        },
        "runBranch": {
          "type": "string",
          "minLength": 1
        },
        "finalCommit": {
          "type": "string",
          "minLength": 1
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "createdCommits": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["commitHash", "message", "phase", "recordedAt"],
            "properties": {
              "commitHash": {
                "type": "string",
                "minLength": 1
              },
              "message": {
                "type": "string",
                "minLength": 1
              },
              "phase": {
                "type": "string",
                "enum": ["engineer-milestone", "final-state"]
              },
              "recordedAt": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "initialWorkingTree": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "changedPaths",
            "hasStagedChanges",
            "hasUnstagedChanges",
            "hasUntrackedChanges",
            "isDirty"
          ],
          "properties": {
            "changedPaths": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "hasStagedChanges": {
              "type": "boolean"
            },
            "hasUnstagedChanges": {
              "type": "boolean"
            },
            "hasUntrackedChanges": {
              "type": "boolean"
            },
            "isDirty": {
              "type": "boolean"
            }
          }
        }
      }
    }
  }
}
