{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/giantsoup/architect-engineer-agentic-harness/schemas/v1/architect-plan.schema.json",
  "title": "ArchitectPlan",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "steps"],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "acceptanceCriteria": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
