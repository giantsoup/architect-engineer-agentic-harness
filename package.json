{
  "name": "architect-engineer-agentic-harness",
  "version": "0.1.0",
  "description": "CLI-first Architect-Engineer coding harness for autonomous repo work.",
  "type": "module",
  "license": "Apache-2.0",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/giantsoup/architect-engineer-agentic-harness#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/giantsoup/architect-engineer-agentic-harness.git"
  },
  "bugs": {
    "url": "https://github.com/giantsoup/architect-engineer-agentic-harness/issues"
  },
  "keywords": [
    "agent",
    "automation",
    "cli",
    "engineering",
    "harness",
    "langgraph"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist",
    "prompts",
    "schemas"
  ],
  "bin": {
    "architect-engineer-agentic-harness": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "verify": "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "prepack": "npm run build",
    "prepublishOnly": "npm run verify"
  },
  "dependencies": {
    "commander": "^14.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/node": "^24.7.2",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.1.2"
  }
}
